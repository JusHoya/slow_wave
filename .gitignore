# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*.pyc

# Build / packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Run outputs (keep the tracked placeholder)
runs/*
!runs/.gitkeep

# Model / embedding caches & weights
.cache/
*.safetensors

# Environment / secrets
.env
.env.*

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# LaTeX build artifacts (the manuscript source is tracked; build output is not).
# We keep paper/main.pdf out of git -- it is regenerated by scripts/build_paper.sh.
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.toc
paper/*.synctex.gz
paper/main.pdf
paper/build.log
paper/sections/*.aux
paper/appendices/*.aux
